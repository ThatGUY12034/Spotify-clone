# admin service — copy to .env and fill in real values
PORT=7000

# Neon Postgres connection string (same DB as the song service)
DB_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require

# Where to validate admin JWTs (the user service)
User_URL=http://localhost:5000

# Cloudinary (audio + thumbnail uploads)
Cloud_Name=<cloud-name>
Cloud_API_Key=<api-key>
Cloud_API_Secret=<api-secret>

# Redis cache password (shared with song service)
Redis_Password=<redis-password>
